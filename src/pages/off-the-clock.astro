---
import { getCollection, render } from 'astro:content';
import Base from '../layouts/Base.astro';
import PageHeader from '../components/PageHeader.astro';
import RecipeCard from '../components/islands/RecipeCard.tsx';
import RiceCalculator from '../components/islands/recipes/rice/RiceCard.tsx';

const [recipe] = await getCollection('recipes');
const { Content: Method } = await render(recipe);

/* PLACEHOLDERS — Andrew's real bikes and games go here. */
const bikes = [
  { name: 'Road bike (placeholder)', note: 'Make / model, and the loop it sees most — one honest line.' },
  { name: 'Second bike (placeholder)', note: 'The other one. Commuter, gravel, whatever it really is.' },
];

const games = [
  { name: 'Current game (placeholder)', note: 'The one actually in the slot right now, and why it stuck.' },
  { name: 'Recently finished (placeholder)', note: 'Last thing you saw credits on — one-line verdict.' },
];

const sectionLabel = 'text-[0.8125rem] font-medium tracking-[0.14em] uppercase text-ink-soft';
---

<Base
  title="Off the clock — Andrew Snider"
  description="Japanese cooking, cycling, and gaming — the concrete artifacts."
>
  <div class="mx-auto w-full max-w-5xl px-6 sm:px-8">
    <PageHeader eyebrow="Off the clock" title="Kitchen, saddle, screen">
      <p class="mt-6 max-w-[46ch] leading-relaxed text-ink-soft">
        {/* PLACEHOLDER intro line */}
        Not a hobbies paragraph — the actual artifacts. A recipe that gets
        cooked, the bikes that get ridden, the games that get finished.
      </p>
    </PageHeader>

    <section class="mt-20" aria-labelledby="kitchen">
      <h2 id="kitchen" class={sectionLabel}>In the kitchen</h2>
      <div
        class="mt-8 grid gap-10 border border-fog/50 bg-paper p-7 sm:grid-cols-[minmax(0,2fr)_minmax(0,3fr)] sm:gap-14 sm:p-10"
        data-rise
      >
        <div>
          <h3 class="font-serif text-3xl">{recipe.data.title}</h3>
          <p class="mt-1 text-sm text-ink-soft">
            {recipe.data.subtitle} &middot; {recipe.data.time}
          </p>
          <div class="mt-8">
            <RecipeCard
              client:visible
              baseServings={recipe.data.baseServings}
              ingredients={recipe.data.ingredients}
            />
          </div>
        </div>
        <div class="prose-quiet max-w-[52ch] text-[0.95rem] sm:pt-1">
          <Method />
        </div>
      </div>

      <div class="mt-6 border border-fog/50 bg-paper p-7 sm:p-10" data-rise>
        <div class="flex flex-wrap items-baseline justify-between gap-x-6 gap-y-1">
          <h3 class="font-serif text-3xl">Rice, solved</h3>
          <p class="text-sm text-ink-soft">pick the rice, everything else is computed</p>
        </div>
        <div class="mt-9">
          <RiceCalculator client:visible />
        </div>
      </div>
    </section>

    <section class="mt-20" aria-labelledby="saddle">
      <h2 id="saddle" class={sectionLabel}>On the bike</h2>
      <ul class="mt-4">
        {
          bikes.map(({ name, note }) => (
            <li class="border-t border-fog/40 py-6 first:border-t-0">
              <p class="font-medium">{name}</p>
              <p class="mt-1 max-w-[52ch] text-sm leading-relaxed text-ink-soft">{note}</p>
            </li>
          ))
        }
      </ul>
    </section>

    <section class="mt-20 pb-12" aria-labelledby="screen">
      <h2 id="screen" class={sectionLabel}>On screen</h2>
      <ul class="mt-4">
        {
          games.map(({ name, note }) => (
            <li class="border-t border-fog/40 py-6 first:border-t-0">
              <p class="font-medium">{name}</p>
              <p class="mt-1 max-w-[52ch] text-sm leading-relaxed text-ink-soft">{note}</p>
            </li>
          ))
        }
      </ul>
    </section>
  </div>
</Base>
