---
import { getCollection } from 'astro:content';
import Base from '../../layouts/Base.astro';
import PageHeader from '../../components/PageHeader.astro';
import ProjectCard from '../../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);
---

<Base title="Building — Andrew Snider" description="Projects and experiments Andrew Snider is building.">
  <div class="mx-auto w-full max-w-5xl px-6 sm:px-8">
    <PageHeader eyebrow="Building" title="Built, and building">
      <p class="mt-6 max-w-[46ch] leading-relaxed text-ink-soft">
        {/* PLACEHOLDER intro line */}
        Side projects with real users, and experiments that might become
        more. Written up honestly — dead ends included.
      </p>
    </PageHeader>
    <ul class="mt-16 pb-12">
      {projects.map((project) => <ProjectCard project={project} />)}
    </ul>
  </div>
</Base>
