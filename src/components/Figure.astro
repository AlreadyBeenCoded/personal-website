---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

/*
 * The one way images appear in prose: framed-print treatment, few and
 * large (the Lauren Waller ratio). Use inside MDX case studies:
 *
 *   import Figure from '../../components/Figure.astro';
 *   import search from '../../assets/projects/partmatch/search.png';
 *   <Figure src={search} alt="…" caption="…" />
 */

interface Props {
  src: ImageMetadata;
  alt: string;
  caption?: string;
}

const { src, alt, caption } = Astro.props;
---

<figure class="my-10">
  <Image
    src={src}
    alt={alt}
    widths={[480, 960, 1440]}
    sizes="(min-width: 64rem) 60rem, 100vw"
    class="img-warm w-full rounded-[2px] border border-fog/40"
  />
  {caption && <figcaption class="mt-3 text-sm text-ink-soft">{caption}</figcaption>}
</figure>
