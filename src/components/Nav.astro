---
const links = [
  { href: '/now', label: 'Now' },
  { href: '/work', label: 'Work' },
  { href: '/building', label: 'Building' },
  { href: '/off-the-clock', label: 'Off the clock' },
];

const currentPath = Astro.url.pathname.replace(/\/$/, '') || '/';
---

<header class="mx-auto flex w-full max-w-5xl flex-wrap items-baseline justify-between gap-x-6 gap-y-2 px-6 pt-8 sm:px-8">
  <a href="/" class="font-medium tracking-tight">Andrew Snider</a>
  <nav aria-label="Main">
    <ul class="flex flex-wrap gap-x-5 gap-y-1 text-sm text-ink-soft sm:gap-x-7">
      {
        links.map(({ href, label }) => (
          <li>
            <a
              href={href}
              aria-current={currentPath === href ? 'page' : undefined}
              class:list={[
                'transition-colors duration-300 hover:text-ink',
                currentPath === href && 'text-ink',
              ]}
            >
              {label}
            </a>
          </li>
        ))
      }
    </ul>
  </nav>
</header>
