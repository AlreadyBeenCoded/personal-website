---
import '@fontsource-variable/instrument-sans';
import '@fontsource/instrument-serif';
import '@fontsource/instrument-serif/400-italic.css';
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';

interface Props {
  title: string;
  description?: string;
  /** Section hue: which room of the site this page belongs to. */
  hue?: 'kaki' | 'sage' | 'clay' | 'stone';
}

const {
  title,
  description = 'Andrew Snider — product manager and independent builder in Salzburg, Austria.',
  hue = 'kaki',
} = Astro.props;

// Absolute URLs for scrapers (og:image must not be relative).
const ogImage = new URL('/og/default.jpg', Astro.site);
const canonical = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="icon" href="/favicon-32.png" type="image/png" sizes="32x32" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="canonical" href={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:site_name" content="Andrew Snider" />
    <meta name="twitter:card" content="summary_large_image" />
    <ClientRouter />
    <script is:inline>
      // Must run before first paint (hence inline + blocking): sets the
      // time-of-day tint so the canvas never flashes the default color,
      // and gates hero-text hiding on the visitor's motion preference.
      // The clock is Salzburg's, not the visitor's: the footer names the
      // daypart ("Evening in Eugendorf"), so the site is a place you
      // visit, and the word must match the mesh it describes.
      (() => {
        const h = Number(
          new Intl.DateTimeFormat('en-GB', { hour: 'numeric', hourCycle: 'h23', timeZone: 'Europe/Vienna' }).format(
            new Date()
          )
        );
        document.documentElement.dataset.daypart =
          h >= 6 && h < 11 ? 'morning' : h >= 11 && h < 16 ? 'midday' : h >= 16 && h < 21 ? 'evening' : 'night';
        if (!matchMedia('(prefers-reduced-motion: reduce)').matches) {
          document.documentElement.classList.add('motion-ok');
        }
      })();
    </script>
  </head>
  <body data-hue={hue} class="flex min-h-svh flex-col">
    <div class="backdrop" aria-hidden="true"></div>
    <a class="skip-link" href="#main">Skip to content</a>
    <Nav />
    <main id="main" class="flex-1">
      <slot />
    </main>
    <Footer />
    <script src="../scripts/motion.ts"></script>
  </body>
</html>
